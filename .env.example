# =============================================================================
# sdd-generator — environment configuration
# Copy to .env and fill in values. .env is git-ignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Claude provider selection
#   cli — Claude Code CLI (default; uses your console subscription via `claude login`)
#   api — Anthropic API   (requires ANTHROPIC_API_KEY)
# -----------------------------------------------------------------------------
SDD_CLAUDE_PROVIDER=cli

# --- provider=cli (Claude Code CLI, default) ---------------------------------
# Path to claude binary. Defaults to "claude" on PATH.
SDD_CLAUDE_CLI_BIN=claude
# Optional model override passed to `claude -p ... --model <id>`.
# SDD_CLAUDE_MODEL=claude-opus-4-7
# Spawn timeout for the CLI in milliseconds (default 120000).
# SDD_CLAUDE_CLI_TIMEOUT_MS=120000

# --- provider=api (Anthropic API) --------------------------------------------
# Required only when SDD_CLAUDE_PROVIDER=api.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# -----------------------------------------------------------------------------
# Generator runtime
# -----------------------------------------------------------------------------
# Logger level: debug | info | warn | error
LOG_LEVEL=info
# Cache directory for prompt/response cache (relative to project root).
SDD_GENERATOR_CACHE=.sdd/cache
# Override built-in templates directory.
# SDD_GENERATOR_TEMPLATES_DIR=./custom-templates
