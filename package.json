{
  "name": "sdd-generator",
  "version": "0.1.0",
  "description": "Spec-anchored development CLI powered by Claude — generates complete SDD documents from interactive brainstorming.",
  "keywords": [
    "sdd",
    "spec-driven",
    "claude",
    "anthropic",
    "cli",
    "code-generation",
    "architecture"
  ],
  "license": "MIT",
  "author": "Eldar Sagitov <salvadore1987@gmail.com>",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sdd": "dist/cli.js",
    "sdd-generator": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "ts-node src/cli.ts",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.js",
    "start": "node dist/cli.js",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:e2e": "jest --selectProjects e2e",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --no-error-on-unmatched-pattern --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"tests/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\" \"tests/**/*.{ts,json}\"",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run type-check && npm test && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "handlebars": "^4.7.8",
    "inquirer": "^9.3.7",
    "ora": "^5.4.1",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
